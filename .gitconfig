[core]
    pager = delta
    editor = nvim

[delta]
    syntax-theme = ansi
    navigate = true  # use n and N to move between diff sections
    side-by-side = true

[diff]
    colorMoved = default

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictstyle = diff3

[pull]
	rebase = true

[rerere]
	enabled = true

[user]
    name = Sebastian Szyller
    email = contact@sebszyller.com
