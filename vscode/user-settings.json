{
  "breadcrumbs.enabled": false,
  "cSpell.language": "en-GB",
  "editor.accessibilitySupport": "off",
  "editor.copyWithSyntaxHighlighting": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "block",
  "editor.formatOnSave": false,
  "editor.fontFamily": "Monaco",
  "editor.fontSize": 14,
  "editor.fontWeight": "bold",
  "editor.largeFileOptimizations": false,
  "editor.lineHeight": 21,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.quickSuggestionsDelay": 1,
  "editor.renderWhitespace": "all",
  "editor.smoothScrolling": true,
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.decorations.badges": false,
  "extensions.ignoreRecommendations": true,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/_site": true,
    "**/*.pyc": true,
    "**/*.asset-cache": true,
    "**/*.cache": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "jupyter.askForKernelRestart": false,
  "latex-workshop.latex.external.build.command": "make",
  "latex-workshop.latex.external.build.args": [
    "all",
    "sweep"
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "notebook.output.textLineLimit": 100,
  "notebook.lineNumbers": "on",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "flake8.args": [
    "--extend-ignore", "E203",
    "--max-line-length", "160"
  ],
  "black-formatter.args": [
    "--line-length", "160"
  ],
  "isort.args": [
    "--profile", "black",
    "--filter-files",
    "--line-length", "160"
  ],
  "[svelte]": {
     "editor.defaultFormatter": "svelte.svelte-vscode",
     "editor.formatOnSave": true
   },
  "svelte.enable-ts-plugin": true,
  "telemetry.telemetryLevel": "off",
  "update.mode": "start",
  "vim.useSystemClipboard": true,
  "vim.cursorStylePerMode.insert": "line",
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.replace": "block",
  "vim.cursorStylePerMode.visual": "block-outline",
  "vim.cursorStylePerMode.visualblock": "block-outline",
  "vim.cursorStylePerMode.visualline": "block-outline",
  "vim.foldfix": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.leader": "<space>",
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": [ "<C-p>" ],
      "after": [ "<Esc>", "p", "a" ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [ "<C-a>" ],
      "after": [ "g", "g", "V", "G" ]
    },
    {
      "before": [ "<C-d>" ],
      "after": [ "<C-d>", "z", "z" ]
    },
    {
      "before": [ "<C-u" ],
      "after": [ "<C-u>", "z", "z" ]
    },
    {
      "before": [ "n" ],
      "after": ["n", "z", "z"]
    },
    {
      "before": [ "N" ],
      "after": ["N", "z", "z"]
    },
    {
      "before": ["u"],
      "commands": ["undo"]
    },
    {
      "before": ["<C-r>"],
      "commands": ["redo"]
    },
    {
      "before": ["<leader>", "f"],
      "after": ["/"]
    },
    {
      "before": ["<leader>", "e"],
      "after": ["$"]
    },
    {
      "before":["<Esc>"],
      "after":["<Esc>"],
      "commands": [ ":nohl" ]
    },
    {
      "before":["<C-c>"],
      "after":["<C-c>"],
      "commands": [ ":nohl" ]
    },
    {
      "before": ["J"],
      "after": ["m", "z", "J", "`", "z", "\"J"]
    }

  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["p"],
      "after": ["p", "g", "v", "y"]
    },
    {
      "before": ["J"],
      "commands": ["editor.action.moveLinesDownAction"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.moveLinesUpAction"]
    }
  ],
  "window.commandCenter": false,
  "window.titleBarStyle": "custom",
  "workbench.colorCustomizations": {},
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "workbench.layoutControl.enabled": false,
  "workbench.statusBar.visible": true,
  "workbench.activityBar.location": "top",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.colorTheme": "Gruvbox Dark Hard",
  "workbench.sideBar.location": "right"
}
