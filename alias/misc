alias gdzie="ps -jef"
alias clpb=pbcopy
alias cl=clear
alias d='dirs -v | head -10'
alias grep="grep --color=always"
alias g=grep
alias l="ls"
alias l1="l -1"
alias la="ls -a"
alias lah="ls -lah"
alias ll="ls -al"
alias py=python3
alias scr="screen -r"
alias scx="screen -XS"
alias scls="screen -ls"
alias t="tree -L 1"
alias tt="tree -L 2"
alias ttt="tree -L 3"
alias shrug="echo \"¯\_(ツ)_/¯ copied to clipboard\" && echo -n \"¯\_(ツ)_/¯\" | clpb"
alias today="date -u +"%Y%m%d""
alias vi=vim
alias yeet="rm -fr"
alias ytdl="youtube-dl"
alias ytdlb="ytdl -f best"

function log_entry_ {
	local=$(today)
	echo "# $(today)" > $(today).md
	echo "Created."
}
alias logentry="log_entry_"

function latcomp_withpdf {
	pdflatex -synctex=1 -interaction=nonstopmode --shell-escape ${1}
}
alias latcomp="latcomp_withpdf"

function cd_overwrite() {
	\cd $1 && ls
}
alias cd="cd_overwrite"

function colored_cat() {
	pygmentize -g ${1}
}
alias ccat="colored_cat"
